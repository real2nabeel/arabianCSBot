# Discord
DISCORD_TOKEN=your-bot-token-here
LOGGING_CHANNEL_ID=887016921705349190
# The only server the bot is allowed to run in (right-click the server icon
# with Developer Mode on -> Copy Server ID)
GUILD_ID=your-server-id-here

# CS 1.6 game server (used by /ip for live player count)
SERVER_IP=151.80.47.182
SERVER_PORT=27015

# MySQL rank databases (two schemas on the same server, sharing credentials):
#   DB_NAME_LIVE -> live/current ranking  (used by /rankstats, /top, ...)
#   DB_NAME      -> historical ranking    (used by /rankstats-history, /top-history, ...)
# Under Docker, 127.0.0.1 points at the bot's own container. Use instead:
#   host.docker.internal -> MySQL running on the Docker host
#   mysql                -> the optional `local-db` compose service
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME_LIVE=liverank
DB_NAME=rankTest
# Bot-owned schema for the Discord activity leveling system (XP + level roles).
# Kept separate from the game ranking data; auto-created on startup.
DB_NAME_BOT=arabianbot

# --- Discord activity leveling (separate from in-game rank) --------------- #
# Text XP: a random amount in [min, max] per message, at most once per cooldown
# (seconds); messages shorter than MIN_MESSAGE_LENGTH chars earn nothing.
TEXT_XP_MIN=15
TEXT_XP_MAX=25
TEXT_XP_COOLDOWN=60
MIN_MESSAGE_LENGTH=3
# Voice XP: granted every VOICE_TICK_SECONDS to members who are not deafened,
# only when at least VOICE_MIN_HUMANS non-bot members share the channel.
VOICE_XP_PER_TICK=10
VOICE_TICK_SECONDS=60
VOICE_MIN_HUMANS=2
# Channels (comma- or space-separated IDs) where text earns no XP.
XP_EXCLUDED_CHANNELS=
# Channel to announce level-ups in. Leave blank to reply where the message was
# sent (text) / stay silent (voice).
LEVELUP_CHANNEL_ID=
